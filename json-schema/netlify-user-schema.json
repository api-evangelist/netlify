{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/user",
  "title": "user",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "affiliate_id": {
      "type": "string"
    },
    "site_count": {
      "type": "integer",
      "format": "int64"
    },
    "created_at": {
      "type": "string",
      "format": "dateTime"
    },
    "last_login": {
      "type": "string",
      "format": "dateTime"
    },
    "login_providers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "onboarding_progress": {
      "type": "object",
      "properties": {
        "slides": {
          "type": "string"
        }
      }
    }
  }
}